// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}
model images {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  file_id String
  url String
  userId String? @unique @db.ObjectId 
  users users? @relation(fields: [userId], references: [id])
}


model users {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  email String @unique
  password String?
  provider String?
  avatar images?
  following String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reviews reviews[]

}

model categories {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  subCategories subCategories[]
  reviews reviews[]
}

model subCategories {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  categoryId String @db.ObjectId
  category categories @relation(fields: [categoryId], references: [id])
  reviews reviews[]
}

model reviews {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  
  // Standard category references
  categoryId String? @db.ObjectId
  category categories? @relation(fields: [categoryId], references: [id])
  subCategoryId String? @db.ObjectId
  subCategory subCategories? @relation(fields: [subCategoryId], references: [id])
  
  // Exceptional category fields for custom user input
  exceptionalCategory String?
  exceptionalSubCategory String?
  isExceptional Boolean @default(false)
  
  productOrService String
  product String
  rating Int
  reviewText String
  photos String[]
  videos String[]
  userId String @db.ObjectId
  user users @relation(fields: [userId], references: [id])
  likes String[]
  comments reviewComments[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model reviewComments {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  text String
  userId String @db.ObjectId
  reviewId String @db.ObjectId
  review reviews @relation(fields: [reviewId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
