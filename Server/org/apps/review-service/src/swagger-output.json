                  "example": "any"
                },
                "product": {
                  "example": "any"
                },
                "rating": {
                  "example": "any"
                },
                "reviewText": {
                  "example": "any"
                },
                "photos": {
                  "example": "any"
                },
                "videos": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
