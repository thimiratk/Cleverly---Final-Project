                  "example": "any"
                },
                "productOrService": {
                  "example": "any"
                },
                "product": {
                  "example": "any"
                },
                "rating": {
                  "example": "any"
                },
                "reviewText": {
                  "example": "any"
                },
                "photos": {
                  "example": "any"
                },
                "videos": {
                  "example": "any"
                },
                "userId": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      },
      "get": {
        "description": "Get reviews",
