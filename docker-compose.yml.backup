# docker-compose.yml
version: '3.8'
services:
  mongo:
    image: mongo:6
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db

  backend:
    build: ./app
    command: uvicorn main:app --host 0.0.0.0 --port 8000 --reload
    depends_on:
      - mongo
    environment:
      - MONGO_URI=mongodb://mongo:27017
      - ML_MODEL_PATH=/app/models/fraud_model.pkl
      - SENTIMENT_API=http://sentiment:8001/sentiment
    ports:
      - "8000:8000"

  sentiment:
    build: ./app
    command: uvicorn sentiment_api:app --host 0.0.0.0 --port 8001
    environment:
      - SENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment
    ports:
      - "8001:8001"

volumes:
  mongo_data:
