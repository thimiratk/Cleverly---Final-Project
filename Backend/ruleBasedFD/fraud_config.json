{
  "fraud_detection_config": {
    "text_analysis": {
      "min_review_length": 10,
      "max_review_length": 5000,
      "max_repeated_chars": 5,
      "max_caps_percentage": 0.7,
      "suspicious_word_threshold": 3
    },
    
    "user_behavior": {
      "max_reviews_per_day": 20,
      "max_reviews_per_hour": 5,
      "min_account_age_days": 1,
      "velocity_window_hours": 24,
      "max_same_rating_streak": 10
    },
    
    "pattern_detection": {
      "similarity_threshold": 0.85,
      "coordinated_attack_threshold": 5,
      "rating_manipulation_threshold": 0.8,
      "ip_review_limit": 10,
      "burst_activity_minutes": 30
    },
    
    "risk_scoring": {
      "weights": {
        "text_analysis": 1.0,
        "user_behavior": 1.2,
        "rating_patterns": 1.1,
        "temporal_patterns": 0.8,
        "technical_patterns": 1.3
      },
      
      "thresholds": {
        "minimal": 0,
        "low": 20,
        "medium": 40,
        "high": 70
      }
    },
    
    "suspicious_patterns": {
      "fake_positive_keywords": [
        "best ever", "amazing product", "highly recommend", "perfect item",
        "five stars", "5 stars", "great quality", "fast shipping",
        "excellent service", "worth every penny", "love it", "fantastic",
        "outstanding", "superb", "incredible", "phenomenal"
      ],
      
      "fake_negative_keywords": [
        "worst ever", "terrible product", "complete waste", "dont buy",
        "scam", "fraud", "fake item", "poor quality", "horrible",
        "disgusting", "awful", "pathetic", "useless", "garbage"
      ],
      
      "spam_indicators": [
        "click here", "visit my", "check out", "follow me",
        "dm me", "contact me", "buy from", "cheap price",
        "limited time", "act now", "special offer", "discount"
      ],
      
      "bot_patterns": [
        "generated by", "created by", "powered by",
        "copy paste", "ctrl c", "ctrl v", "automated",
        "script", "bot", "robot"
      ]
    },
    
    "actions": {
      "high_risk": [
        "block_review",
        "flag_user_account",
        "manual_review_required",
        "investigate_coordinated_attack",
        "temporary_account_suspension"
      ],
      
      "medium_risk": [
        "hold_for_approval",
        "increase_monitoring",
        "require_verification",
        "add_to_watchlist"
      ],
      
      "low_risk": [
        "allow_with_monitoring",
        "add_to_pattern_detection"
      ]
    }
  }
